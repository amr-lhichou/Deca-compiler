#include "Math.decah"
{
    Math m = new Math();

    println(" Tests cos(x) ");

    println("cos(0.0) = ", m.cos(0.0));
    println("cos(pi/6) = ", m.cos(3.14159265 / 6));
    println("cos(pi/4) = ", m.cos(3.14159265 / 4));
    println("cos(pi/3) = ", m.cos(3.14159265 / 3));
    println("cos(pi/2) = ", m.cos(3.14159265 / 2));

    println("cos(pi) = ", m.cos(3.14159265));
    println("cos(2*pi) = ", m.cos(2 * 3.14159265));

    println("cos(-pi/3) = ", m.cos(-3.14159265 / 3));
    println("cos(10*pi) = ", m.cos(10 * 3.14159265));
}
