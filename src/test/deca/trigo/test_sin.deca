#include "Math.decah"
{
    Math m = new Math();

    println(" Tests sin(x) ");

    println("sin(0.0) = ", m.sin(0.0));
    println("sin(pi/6) = ", m.sin(3.14159265 / 6));
    println("sin(pi/4) = ", m.sin(3.14159265 / 4));
    println("sin(pi/3) = ", m.sin(3.14159265 / 3));
    println("sin(pi/2) = ", m.sin(3.14159265 / 2));

    println("sin(pi) = ", m.sin(3.14159265));
    println("sin(2*pi) = ", m.sin(2 * 3.14159265));

    println("sin(-pi/4) = ", m.sin(-3.14159265 / 4));
    println("sin(7*pi/2) = ", m.sin(7 * 3.14159265 / 2));
}
