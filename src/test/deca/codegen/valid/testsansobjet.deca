// test_sans_objet.deca

{
    // Déclarations + initialisations
    int i = 0;
    int acc = 0;
    int a = 7;
    int b = 3;
    int sum = a + b;
    int prod = a * b;
    float f = 2.5;
    float g = f * 4.0;

    boolean ok = (sum > 0) && (prod > 0);

    print("a="); print(a); println("");
    print("b="); print(b); println("");
    print("sum="); print(sum); println("");
    print("prod="); print(prod); println("");

    print("g="); print(g); println("");

    // if / else
    if (ok) {
        println("ok=true");
    } else {
        println("ok=false");
    }

    // while

    while (i < 5) {
        acc = acc + i;
        i = i + 1;
    }
    print("acc="); print(acc); println(""); // doit afficher 10
}
