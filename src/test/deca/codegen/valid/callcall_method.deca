class B {
    int u() { return 1; }
    int v() { return 2; }
    int w() { return 3; }
    int x() { return 4; }
    int y() { return 5; }
    int z() { return 6; }

    int messi() {
        return this.u() + (this.v() + (this.w() + (this.x() + (this.y() + this.z()))));
    }
}

{
    B b = new B();
    int A = 10;
    int t = 20;
    int C = 30;
    println(A + (t + (C + b.messi())));
}
