// Description :
//    comparaisons : == != < <= > >= via if.
//    On encode vrai=1 faux=0.

// Resultats :

//    1
//    1
//    1
//    1
//    1
//    1


{
    if (3 == 3) { 
        println(1); } else { println(0); 
        }

    if (3 != 4) { 
        println(1); } else { println(0); 
        }

    if (2 < 3)  { 
        println(1); } else { println(0);
        }

    if (2 <= 2) { 
        println(1); } else { println(0); 
        }

    if (4 > 3)  { 
        println(1); } else { println(0); 
        }
        
    if (4 >= 4) { 
        println(1); } else { println(0); 
        }
}