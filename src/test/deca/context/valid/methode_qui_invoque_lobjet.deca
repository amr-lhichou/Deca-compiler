class Footballer {
    int shirtNumber;

    void setNumber(int num) {
        shirtNumber = num;
    }

    void printNumber() {
        println(shirtNumber);
    }
}

{
    Footballer f;
    f = new Footballer();
    f.setNumber(10);
    f.printNumber();
}
